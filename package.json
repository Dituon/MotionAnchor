{
  "name": "motion-anchor",
  "private": true,
  "license": "AGPL-3.0-only",
  "version": "0.1.1",
  "type": "module",
  "workspaces": [
    "apps/site"
  ],
  "scripts": {
    "dev": "vite",
    "dev:site": "npm --workspace @motion-anchor/site run dev",
    "build": "npm run build:desktop",
    "build:desktop": "tsc && vite build",
    "build:site": "npm --workspace @motion-anchor/site run build",
    "build:all": "npm run build:desktop && npm run build:site",
    "preview": "vite preview",
    "preview:site": "npm --workspace @motion-anchor/site run preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@heroui/react": "^3.2.2",
    "@heroui/styles": "^3.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.4.3",
    "animejs": "^4.5.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
